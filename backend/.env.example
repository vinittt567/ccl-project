# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Supabase (from https://app.supabase.com -> Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# JWT Secret (generate a random 64+ char string)
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-project.vercel.app

# Node environment
NODE_ENV=production
